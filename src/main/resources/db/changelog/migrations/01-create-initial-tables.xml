<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1" author="Contrad">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="courses">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="teacher_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_course_teacher" referencedTableName="users" referencedColumnNames="id"/>
            </column>
        </createTable>

        <createTable tableName="lessons">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2000)"/>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_lesson_course" referencedTableName="courses" referencedColumnNames="id"/>
            </column>
        </createTable>

        <createTable tableName="assignments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="lesson_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_assignment_lesson" referencedTableName="lessons" referencedColumnNames="id"/>
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_assignment_course" referencedTableName="courses" referencedColumnNames="id"/>
            </column>
        </createTable>

        <createTable tableName="submissions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2000)"/>
            <column name="grade" type="DECIMAL(5,2)"/>
            <column name="submitted_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_submission_student" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="assignment_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_submission_assignment" referencedTableName="assignments" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>